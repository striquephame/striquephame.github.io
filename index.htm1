.btn{display:inline-block;padding:12px 28px;margin:5px;background:#d4af37;color:#000;text-decoration:none;font-weight:bold;border-radius:4px}
.btn-outline{background:transparent;border:2px solid #d4af37;color:#d4af37}
section{padding:60px 20px;max-width:900px;margin:auto;text-align:center}
h2{color:#d4af37;margin-bottom:20px;font-size:2rem}
.video{aspect-ratio:16/9;width:100%;max-width:700px;margin:20px auto}
.video iframe{width:100%;height:100%;border:none}
.grid{display:grid;gap:15px;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));margin-top:30px}
.card{background:#111;padding:20px;border-radius:8px}
footer{background:#000;padding:30px 20px;text-align:center;font-size:.9rem}
@media(max-width:600px){.hero h1{font-size:2.2rem}.hero p{font-size:1rem}}
</style>
