<title>STRIQUE PHAME | Afrobeat Highlife</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Arial,sans-serif;background:#0a0a0a;color:#fff;line-height:1.6}
.hero{height:100vh;background:linear-gradient(rgba(0,0,0,.3),rgba(0,0,0,.7)),url('hero.jpg') center/cover;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:20px}
.hero h1{font-size:3rem;letter-spacing:2px;color:#d4af37}
